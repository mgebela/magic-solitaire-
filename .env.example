# Server
PORT=3000
NODE_ENV=development

# Database (Milestone 3)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/three_towers

# Redis (Milestone 8)
REDIS_URL=redis://localhost:6379

# Auth (Milestone 2)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-too
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:3000

# OAuth (Milestone 2 — stubs until credentials configured)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Client (leave empty to use Vite proxy in dev, or nginx proxy in Docker prod)
VITE_API_URL=

# Docker production (see docker/.env.example)
# npm run docker:up — full stack on http://localhost

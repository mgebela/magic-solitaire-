{
  "name": "@three-towers/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "prisma generate && tsc && concurrently -k \"tsc -w --preserveWatchOutput\" \"nodemon -q --watch dist --delay 0.5 dist/main.js\"",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No lint configured yet'",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/websockets": "^11.1.3",
    "@prisma/client": "^6.9.0",
    "@three-towers/game-engine": "*",
    "@three-towers/shared": "*",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.29",
    "@types/passport-jwt": "^4.0.1",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
